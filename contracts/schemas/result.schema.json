{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "iScope360 Result",
  "type": "object",
  "required": ["metadata", "status", "execution"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["task_id", "agent_id", "module", "timestamp"],
      "properties": {
        "task_id": { "type": "string", "format": "uuid" },
        "agent_id": { "type": "string" },
        "module": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["success", "failed", "partial"]
    },
    "execution": {
      "type": "object",
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "retries": { "type": "integer", "minimum": 0 },
        "resources": {
          "type": "object",
          "properties": {
            "cpu_avg": { "type": "number" },
            "memory_peak_mb": { "type": "integer" }
          }
        }
      }
    },
    "data": {
      "type": "object",
      "description": "Normalized output data from the module"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" },
          "details": { "type": "object" }
        }
      }
    }
  }
}
