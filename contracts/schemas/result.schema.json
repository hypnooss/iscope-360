{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "iScope360 Result v1.4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "status",
    "execution",
    "data"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "correlation_id",
        "agent_id",
        "tenant_id",
        "module",
        "timestamp"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "format": "uuid"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "agent_id": {
          "type": "string"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "module": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "origin_agent_id": {
          "type": "string"
        },
        "via_proxy": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "partial"
      ]
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duration_ms",
        "retries",
        "steps"
      ],
      "properties": {
        "duration_ms": {
          "type": "integer"
        },
        "retries": {
          "type": "integer"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "status",
              "duration_ms"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "success",
                  "failed",
                  "skipped"
                ]
              },
              "duration_ms": {
                "type": "integer"
              },
              "error": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "code": {
                    "type": "integer"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu_usage": {
              "type": "number"
            },
            "memory_usage": {
              "type": "number"
            },
            "peak_memory_context": {
              "type": "number"
            }
          }
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_data",
        "normalized_data",
        "inventory",
        "findings"
      ],
      "properties": {
        "raw_data": {
          "type": "object"
        },
        "normalized_data": {
          "type": "object"
        },
        "inventory": {
          "type": "array"
        },
        "findings": {
          "type": "array"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "step_id"
      ],
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string"
        },
        "step_id": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}