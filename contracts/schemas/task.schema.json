{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "iScope360 Task v1.4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "correlation_id",
    "tenant_id",
    "module",
    "action",
    "execution_requirements",
    "payload"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "format": "uuid"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string",
      "format": "uuid"
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "action": {
      "type": "string",
      "enum": [
        "execute"
      ]
    },
    "execution_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "pool",
            "dedicated"
          ]
        },
        "pool": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required_agent_type": {
              "type": "string"
            },
            "required_capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "dedicated": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "target_agent_id": {
              "type": "string"
            }
          }
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "params"
      ],
      "properties": {
        "params": {
          "type": "object"
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "timeout": {
              "type": "integer"
            },
            "cpu": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "rate": {
              "type": "string",
              "enum": [
                "safe",
                "aggressive"
              ]
            }
          }
        }
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "retry": {
          "type": "integer"
        },
        "schedule": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "immediate",
                "cron"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signed": {
          "type": "boolean"
        },
        "signature": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_by": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "system",
            "user",
            "automation"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}